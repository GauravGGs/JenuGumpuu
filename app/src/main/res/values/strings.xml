    <string name="moisture_check_title">How to Check Moisture Level?</string>
    <string name="spoon_test_title">1. The Spoon Test (Traditional)</string>
    <string name="spoon_test_desc">Lift a spoon of honey. If it falls in a continuous \'string\' without breaking, moisture is LOW (Grade A). If it drips like water, moisture is HIGH.</string>
    <string name="thumb_test_title">2. The Thumb Test</string>
    <string name="thumb_test_desc">Put a drop on your thumb. Pure, low-moisture honey stays intact. High-moisture honey will spread or spill immediately.</string>
    <string name="refract_test_title">3. Refractometer (Professional)</string>
    <string name="refract_test_desc">Use a honey refractometer to get an exact percentage. Ideal is below 18%.</string>
    <string name="shade_guide_title">Visual Shade Guide</string>
    <string name="grade_a_details">Color: Extra White / Pale Gold\nSource: Coffee Blossom\nMoisture: &lt; 18%</string>
    <string name="grade_b_details">Color: Light Amber\nSource: Wildflower\nMoisture: 18-20%</string>
    <string name="grade_c_details">Color: Dark Amber\nSource: Forest Multifloral\nMoisture: &gt; 20%</string>
    <string name="back_to_dashboard">Back to Dashboard</string>

    <string name="how_to_grade_title">How to Grade Using this App?</string>
    <string name="step_1_title">1. Match the Color</string>
    <string name="step_1_desc">Hold your real jar of honey next to the screen. Match the liquid color to the Shade Guide blocks below.</string>
    <string name="step_2_title">2. Check Flow (Moisture)</string>
    <string name="step_2_desc">Use the Spoon Test or Thumb Test described below to estimate the moisture percentage.</string>
    <string name="step_3_title">3. Assign the Grade</string>
    <string name="step_3_desc">Once color and moisture match, categorize your honey as Grade A, B, or C during the Harvest Log entry.</string>

    <string name="sustainable_desc">How to harvest without killing the bee colony</string>
    <string name="smoke_title">1. Smoke usage</string>
    <string name="smoke_desc">Use cool, natural smoke to calm bees. Avoid high heat that can burn their wings.</string>
    <string name="portion_title">2. Leave 1/3 portion</string>
    <string name="portion_desc">Always leave one-third of the honeycomb for the bees to survive and regrow.</string>
    <string name="queen_title">3. Save the Queen</string>
    <string name="queen_desc">Ensure the queen bee and the brood (eggs) are not harmed during the process.</string>
